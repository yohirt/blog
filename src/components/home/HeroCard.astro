---
import { withBase } from "@/utils/paths";

interface Props {
  imageUrl: string;
  title?: string;
  link?: string;
}

const {
  imageUrl,
  title = "Home",
  link = ""
} = Astro.props;
---

<div class="hero-card relative z-20 w-full">
  <a
    href={link ? withBase(link) : undefined}
    aria-label={title}
    class:list={[
      "block overflow-hidden rounded-xl border border-primary/40 dark:border-primary/60",
      !link && "pointer-events-none"
    ]}
  >
    <img
      src={withBase(imageUrl)}
      alt={title}
      loading="eager"
      decoding="auto"
      class="block aspect-[6/7] w-full object-cover"
    />
  </a>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const card = document.querySelector(".hero-card") as HTMLElement | null;

    if (!card || window.innerWidth < 768) return;

    let mouseX = 0;
    let mouseY = 0;
    let currentX = 0;
    let currentY = 0;
    const strength = 18;
    const easing = 0.08;

    document.addEventListener("mousemove", (event: MouseEvent) => {
      mouseX = event.clientX / window.innerWidth - 0.5;
      mouseY = event.clientY / window.innerHeight - 0.5;
    });

    const animate = () => {
      const targetX = mouseX * strength;
      const targetY = mouseY * strength;

      currentX += (targetX - currentX) * easing;
      currentY += (targetY - currentY) * easing;

      card.style.transform = `translate3d(${currentX}px, ${currentY}px, 0)`;
      requestAnimationFrame(animate);
    };

    animate();
  });
</script>

<style>
  .hero-card {
    will-change: transform;
  }
</style>
